www.app.vsos.ethz.ch app.vsos.ethz.ch {
	redir {$VMWIZ_SCHEME}://{$VMWIZ_HOSTNAME}
}

{$VMWIZ_SCHEME}://{$VMWIZ_HOSTNAME} {$VMWIZ_SCHEME}://www.{$VMWIZ_HOSTNAME} {
	log {
    output file /var/log/caddy/caddy.log
    level DEBUG
  }

  reverse_proxy /api/* http://vmwiz-backend:8081 {
    # Flush immediately so logs streamed to the frontend are not buffered
    flush_interval -1
  }

  reverse_proxy http://vmwiz-frontend:3000
}
